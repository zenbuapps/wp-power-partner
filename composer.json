{
	"name": "zenbuapps/wp-power-partner",
	"description": "Power Partner 是一個 WordPress 套件，安裝後，可以讓你的 Woocommerce 商品與 cloud.luke.cafe 的模板網站連結，並且可以讓使用者自訂商品的價格，當用戶在您的網站下單後，會自動在 cloud.luke.cafe 創建網站，並且自動發送通知給用戶跟您。",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-only",
	"authors": [
		{
			"name": "JerryLiu",
			"email": "j7.dev.gg@gmail.com",
			"homepage": "https://github.com/j7-dev",
			"role": "Developer"
		}
	],
	"repositories": [
		{
			"type": "composer",
			"url": "https://wpackagist.org"
		}
	],
	"autoload": {
		"psr-4": {
			"J7\\PowerPartner\\": "inc/classes/"
		}
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true,
			"phpstan/extension-installer": true,
			"composer/installers": true,
			"pestphp/pest-plugin": true
		}
	},
	"require": {
		"kucrut/vite-for-wp": "^0.8.0",
		"j7-dev/wp-plugin-trait": "0.2.7"
	},
	"require-dev": {
		"squizlabs/php_codesniffer": "@stable",
		"wp-coding-standards/wpcs": "@stable",
		"dealerdirect/phpcodesniffer-composer-installer": "@stable",
		"phpcompatibility/php-compatibility": "@stable",
		"phpstan/phpstan": "@stable",
		"php-stubs/wordpress-stubs": "@stable",
		"phpstan/extension-installer": "@stable",
		"pestphp/pest": "^1.23",
		"dingo-d/wp-pest": "^1.6",
		"php-stubs/woocommerce-subscriptions-stubs": "^8.4",
		"phpunit/phpunit": "^9.0",
		"wp-phpunit/wp-phpunit": "^6.0",
		"yoast/phpunit-polyfills": "^1.0"
	},
	"autoload-dev": {
		"psr-4": {
			"Tests\\Integration\\": "tests/Integration/"
		}
	},
	"scripts": {
		"lint": "phpcs",
		"test": "vendor\\bin\\phpunit --testsuite Integration --colors=always --testdox --verbose",
		"test:smoke": "vendor\\bin\\phpunit --testsuite Integration --group smoke --colors=always --testdox",
		"test:happy": "vendor\\bin\\phpunit --testsuite Integration --group happy --colors=always --testdox",
		"test:error": "vendor\\bin\\phpunit --testsuite Integration --group error --colors=always --testdox",
		"test:edge": "vendor\\bin\\phpunit --testsuite Integration --group edge --colors=always --testdox"
	}
}
